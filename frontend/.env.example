# Copy to `.env` and adjust. All vars are optional.

# Backend selection for src/services/index.js:
#   auto  (default) — real backend, fall back to mock if unreachable
#   false           — always real backend
#   true            — always in-memory mock (no backend required)
VITE_USE_MOCK=auto

# Override the backend origin. Leave empty to use the Vite dev proxy (/api -> :8080).
# VITE_API_BASE=http://localhost:8080
